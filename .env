# DSS environment configuration example
# Copy to .env and adjust values before launch.
# All values below reflect production-safe defaults.

# --- Coordinator (server) ---
DSS_SERVER_HOST=0.0.0.0
DSS_SERVER_PORT=8000
DSS_JWT_SECRET=123456789
DSS_JWT_EXPIRE_MINUTES=60
DSS_NETWORK_MODE=global
DSS_ALLOWED_IPS=
DSS_HEARTBEAT_TIMEOUT=30
DSS_HEALTH_INTERVAL=15
DSS_DATA_SHARDS=4
DSS_TOTAL_SHARDS=6

# --- Peer Node (client) ---
DSS_NODE_HOST=0.0.0.0
DSS_NODE_PORT=8100
DSS_COORDINATOR_URL=http://localhost:8000
DSS_IDENTITY_DIR=~/.dss/identity
DSS_STORAGE_DIR=~/.dss/shards
DSS_HEARTBEAT_INTERVAL=15
DSS_ADVERTISED_HOST=127.0.0.1
DSS_CAPACITY=10737418240

# --- UI ---
NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8000
NEXT_PUBLIC_NODE_URL=http://localhost:8100
