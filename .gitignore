# DSS .gitignore

# Digest files
digest.txt

# Environment variables
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# Identity and shard data — never commit private keys or stored shards
.dss/
*.pem

# Next.js
ui/.next/
ui/node_modules/
ui/out/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# IDEs
.idea/
.vscode/
*.swp
